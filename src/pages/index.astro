      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: var(--c-green-bg-10);
      border: 1px solid var(--c-green-border-20);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      color: var(--c-green-text-60);
    }
    .empty-state-title {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--c-text-80);
      margin-bottom: 0.5rem;
    }
    .empty-state-desc {
      font-size: 0.875rem;
      color: var(--c-text-40);
      max-width: 280px;
      line-height: 1.5;
    }

