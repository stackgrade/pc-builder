---
import Layout from '../layouts/Layout.astro';
import PriceData from '../../data/prices.json';

const { components, updated } = PriceData;

const bestCpu = [...components.cpus].sort((a, b) => b.performancePerKrona - a.performancePerKrona)[0];
const bestGpu = [...components.gpus].sort((a, b) => b.performancePerKrona - a.performancePerKrona)[0];

const topValue = {
  cpus: [...components.cpus].sort((a, b) => b.performancePerKrona - a.performancePerKrona).slice(0, 3),
  gpus: [...components.gpus].sort((a, b) => b.performancePerKrona - a.performancePerKrona).slice(0, 3),
};

const formatPrice = (price: number) => `${price.toLocaleString('sv-SE')} kr`;
const formatDate = (dateStr: string) => new Date(dateStr).toLocaleDateString('sv-SE', { 
  day: 'numeric', 
  month: 'short', 
  hour: '2-digit', 
  minute: '2-digit' 
});
---

<Layout title="PC Builder SE - Bäst pris per krona">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="text-center mb-12">
      <h1 class="text-4xl font-extrabold mb-2">
        PC Builder <span class="text-accent">SE</span>
      </h1>
      <p class="text-gray-400 text-lg">Hitta bästa prestanda per krona för din nästa dator</p>
      <p class="text-gray-600 text-sm mt-2">Priser uppdaterade: {formatDate(updated)}</p>
    </header>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
      <div class="bg-gradient-to-br from-blue-900/50 to-dark border border-accent/30 rounded-2xl p-6 relative">
        <span class="inline-block px-3 py-1 bg-accent/20 text-accent text-xs font-semibold rounded-full mb-3">🏆 BÄST PRIS/KRONA</span>
        <h2 class="text-xl font-bold mb-4">{bestCpu.name}</h2>
        <div class="flex gap-4 mb-4">
          <span class="text-2xl font-bold">{formatPrice(bestCpu.price)}</span>
          <span class="text-gray-400 self-center">{bestCpu.performance} poäng</span>
        </div>
        <div class="text-center bg-black/30 rounded-lg p-4">
          <span class="block text-4xl font-extrabold text-accent">{bestCpu.performancePerKrona}</span>
          <span class="text-gray-500 text-xs">prestanda per 1000 kr</span>
        </div>
      </div>

      <div class="bg-gradient-to-br from-amber-900/30 to-dark border border-amber-500/30 rounded-2xl p-6 relative">
        <span class="inline-block px-3 py-1 bg-amber-500/20 text-amber-400 text-xs font-semibold rounded-full mb-3">🎮 BÄST GRAFIK</span>
        <h2 class="text-xl font-bold mb-4">{bestGpu.name}</h2>
        <div class="flex gap-4 mb-4">
          <span class="text-2xl font-bold">{formatPrice(bestGpu.price)}</span>
          <span class="text-gray-400 self-center">{bestGpu.performance} poäng</span>
        </div>
        <div class="text-center bg-black/30 rounded-lg p-4">
          <span class="block text-4xl font-extrabold text-amber-400">{bestGpu.performancePerKrona}</span>
          <span class="text-gray-500 text-xs">prestanda per 1000 kr</span>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h3 class="text-xl font-bold mb-4">Utforska komponenter</h3>
      <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
        <a href="#cpus" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">⚡</span>
          <span class="text-sm font-medium block">Processorer</span>
          <span class="text-xs text-gray-500">{components.cpus.length} artiklar</span>
        </a>
        <a href="#gpus" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">🎮</span>
          <span class="text-sm font-medium block">Grafikkort</span>
          <span class="text-xs text-gray-500">{components.gpus.length} artiklar</span>
        </a>
        <a href="#motherboards" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">🔌</span>
          <span class="text-sm font-medium block">Moderkort</span>
          <span class="text-xs text-gray-500">{components.motherboards.length} artiklar</span>
        </a>
        <a href="#ram" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">💾</span>
          <span class="text-sm font-medium block">Internminne</span>
          <span class="text-xs text-gray-500">{components.ram.length} artiklar</span>
        </a>
        <a href="#storage" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">💿</span>
          <span class="text-sm font-medium block">Lagring</span>
          <span class="text-xs text-gray-500">{components.storage.length} artiklar</span>
        </a>
        <a href="#cases" class="bg-card border border-border rounded-xl p-4 text-center hover:border-accent hover:-translate-y-1 transition-all cursor-pointer">
          <span class="text-2xl block mb-1">📦</span>
          <span class="text-sm font-medium block">Chassin</span>
          <span class="text-xs text-gray-500">{components.cases.length} artiklar</span>
        </a>
      </div>
    </section>

    <section id="cpus" class="mb-8">
      <h3 class="text-xl font-bold mb-4">⚡ Processorer</h3>
      <div class="flex flex-col gap-3">
        {topValue.cpus.map((cpu, i) => (
          <div class={`bg-card border rounded-xl p-4 relative ${i === 0 ? 'border-accent/50 bg-gradient-to-r from-card to-green-900/20' : 'border-border'}`}>
            {i === 0 && <span class="absolute -top-2 right-4 bg-accent text-black text-xs font-bold px-2 py-0.5 rounded">TOP VAL</span>}
            <div class="flex justify-between items-center mb-3">
              <h4 class="font-semibold">{cpu.name}</h4>
              <span class="text-xs text-gray-500">{cpu.retailer}</span>
            </div>
            <div class="flex justify-between items-center">
              <div class="text-xl font-bold">{formatPrice(cpu.price)}</div>
              <div class="flex gap-6">
                <div class="text-center">
                  <span class="block text-lg font-bold">{cpu.performance}</span>
                  <span class="text-xs text-gray-500">Prestanda</span>
                </div>
                <div class="text-center">
                  <span class="block text-lg font-bold text-accent">{cpu.performancePerKrona}</span>
                  <span class="text-xs text-gray-500">per 1000 kr</span>
                </div>
              </div>
              <a href={cpu.url} class="bg-gray-800 hover:bg-accent hover:text-black text-sm font-medium px-4 py-2 rounded-lg transition-colors">Se pris →</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="gpus" class="mb-8">
      <h3 class="text-xl font-bold mb-4">🎮 Grafikkort</h3>
      <div class="flex flex-col gap-3">
        {topValue.gpus.map((gpu, i) => (
          <div class={`bg-card border rounded-xl p-4 relative ${i === 0 ? 'border-amber-500/50 bg-gradient-to-r from-card to-amber-900/20' : 'border-border'}`}>
            {i === 0 && <span class="absolute -top-2 right-4 bg-amber-400 text-black text-xs font-bold px-2 py-0.5 rounded">TOP VAL</span>}
            <div class="flex justify-between items-center mb-3">
              <h4 class="font-semibold">{gpu.name}</h4>
              <span class="text-xs text-gray-500">{gpu.retailer}</span>
            </div>
            <div class="flex justify-between items-center">
              <div class="text-xl font-bold">{formatPrice(gpu.price)}</div>
              <div class="flex gap-6">
                <div class="text-center">
                  <span class="block text-lg font-bold">{gpu.performance}</span>
                  <span class="text-xs text-gray-500">Prestanda</span>
                </div>
                <div class="text-center">
                  <span class="block text-lg font-bold text-amber-400">{gpu.performancePerKrona}</span>
                  <span class="text-xs text-gray-500">per 1000 kr</span>
                </div>
              </div>
              <a href={gpu.url} class="bg-gray-800 hover:bg-amber-400 hover:text-black text-sm font-medium px-4 py-2 rounded-lg transition-colors">Se pris →</a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <footer class="text-center py-8 border-t border-border text-gray-500 text-sm">
      <p>Data från svenska återförsäljare • Priser uppdateras var 6:e timme</p>
      <p class="mt-1 text-xs">Inget binds, alla priser är cirkapris. Kontrollera alltid hos återförsäljare.</p>
    </footer>
  </main>
</Layout>
