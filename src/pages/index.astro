---

<Layout
  title="PC Builder SE — Bästa prestanda per krona"
  description="Bygg din drömdator med PC Builder SE. Automatisk optimering av prestanda per krona med priser från svenska återförsäljare. 4 prissegment från 7 000 till 20 000 kr."
  type="website"
>
  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
    }
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(34,197,94,0.3); }
      50% { box-shadow: 0 0 40px rgba(34,197,94,0.5); }
    }
    @keyframes gradient-shift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .animate-float { animation: float 4s ease-in-out infinite; }
    .animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
    .animate-gradient {
      background-size: 200% 200%;
      animation: gradient-shift 4s ease infinite;
    }
    .glass {
      background: var(--c-glass);
      backdrop-filter: blur(16px);
      border: 1px solid var(--c-border-08);
    }
    .glass-strong {
      background: var(--c-glass-strong);
      backdrop-filter: blur(20px);
      border: 1px solid var(--c-border-10);
    }
    .card-hover {
      transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }
    .tier-btn {
      transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
      position: relative;
      overflow: hidden;
      cursor: pointer;
      min-height: 44px;
    }
    .tier-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--c-green-bg-10) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .tier-btn:hover::before { opacity: 1; }
    .tier-btn:hover { transform: translateY(-2px); border-color: var(--c-green-border-40); }
    .tier-btn.active {
      border-color: var(--c-green-border-40);
      box-shadow: 0 0 30px rgba(34,197,94,0.2), inset 0 0 30px rgba(34,197,94,0.05);
    }
    .tier-btn.active::before { opacity: 1; }
    .retailer-btn {
      background: linear-gradient(135deg, var(--c-green-bg-10) 0%, transparent 100%);
      border: 1px solid var(--c-green-border-30);
      transition: all 0.25s;
      cursor: pointer;
    }
    .retailer-btn:hover {
      background: linear-gradient(135deg, var(--c-green-bg-20) 0%, var(--c-green-bg-10) 100%);
      border-color: var(--c-green-border-40);
      transform: scale(1.02);
    }
    .summary-card {
      background: var(--c-summary);
      border: 1px solid var(--c-border-06);
      transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
      cursor: pointer;
    }
    .summary-card:hover {
      border-color: var(--c-green-border-30);
      transform: translateY(-3px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.25);
    }
    .summary-card.active {
      border-color: var(--c-green-border-40);
      background: var(--c-summary-active);
    }
    .gradient-text {
      background: var(--c-gradient-text);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-gradient {
      background: var(--c-hero-gradient);
    }
    .build-card {
      background: var(--c-built-card-bg);
      border: 1px solid var(--c-border-08);
      border-radius: 24px;
      position: relative;
    }
    .build-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: var(--c-built-card-border-top);
    }
    .component-card {
      background: var(--c-glass);
      border: 1px solid var(--c-border-06);
      border-radius: 16px;
      transition: all 0.3s;
    }
    .component-card:hover {
      border-color: var(--c-green-border-30);
      background: var(--c-glass-strong);
    }
    .perf-bar {
      height: 4px;
      border-radius: 2px;
      background: var(--c-perf-bar);
      overflow: hidden;
    }
    .perf-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
    }
    .icon-container {
      background: linear-gradient(135deg, var(--c-green-bg-20) 0%, var(--c-green-bg-10) 100%);
      border: 1px solid var(--c-green-border-20);
      border-radius: 12px;
    }
    .stat-card {
      background: var(--c-stat);
      border: 1px solid var(--c-border-06);
      border-radius: 16px;
    }
    .live-dot {
      animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(1.1); }
    }
    .build-section { display: none; }
    .build-section.visible { display: block; }
    .tier-card { display: none; }
    .tier-card.visible { display: block; }

    .comp-grid { display: none; }
    .comp-grid.visible { display: block; }

    /* Theme-aware text utilities — override UnoCSS color classes */
    .c-text { color: var(--c-text); }
    .c-text-90 { color: var(--c-text-90); }
    .c-text-80 { color: var(--c-text-80); }
    .c-text-70 { color: var(--c-text-70); }
    .c-text-50 { color: var(--c-text-50); }
    .c-text-40 { color: var(--c-text-40); }
    .c-text-30 { color: var(--c-text-30); }
    .c-text-25 { color: var(--c-text-25); }
    .c-border-10 { border-color: var(--c-border-10); }
    .c-border-08 { border-color: var(--c-border-08); }
    .c-border-06 { border-color: var(--c-border-06); }
    .c-bg-white-5 { background: var(--c-bg-white-5); }
    .c-perf-bar { background: var(--c-perf-bar); }
    .c-green-text { color: var(--c-green-text); }
    .c-green-text-60 { color: var(--c-green-text-60); }
    .c-green-text-70 { color: var(--c-green-text-70); }
    .c-divider { background: var(--c-divider); }

    @media (max-width: 374px) {
      .tier-btn { padding: 1rem; }
      .tier-btn .text-3xl { font-size: 1.5rem; line-height: 1.75rem; }
    }
    @media (max-width: 639px) {
      .stat-card { min-height: 88px; }
      .build-stats .text-2xl { font-size: 1.25rem; }
      .summary-card { cursor: pointer; }
      .retailer-btn { min-height: 36px; display: inline-flex; align-items: center; }
    }
    .grid > * { min-width: 0; }

    /* Skeleton shimmer animation */
    @keyframes shimmer {
      0% { background-position: -200px 0; }
      100% { background-position: calc(200px + 100%) 0; }
    }
    .skeleton {
      background: linear-gradient(90deg, var(--c-bg-white-5) 25%, var(--c-glass) 50%, var(--c-bg-white-5) 75%);
      background-size: 200px 100%;
      animation: shimmer 1.5s ease-in-out infinite;
      border-radius: 12px;
    }
    .skeleton-card {
      min-height: 120px;
      border: 1px solid var(--c-border-06);
      background: var(--c-glass);
    }
    .skeleton-card.shimmer {
      background: linear-gradient(90deg, var(--c-glass) 25%, var(--c-glass-strong) 50%, var(--c-glass) 75%);
      background-size: 200px 100%;
      animation: shimmer 1.5s ease-in-out infinite;
    }
    .skeleton-text {
      height: 14px;
      border-radius: 6px;
      margin-bottom: 8px;
    }
    .skeleton-text.w-30 { width: 30%; }
    .skeleton-text.w-50 { width: 50%; }
    .skeleton-text.w-70 { width: 70%; }
    .skeleton-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
    }

    /* Empty state styling */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 3rem 1.5rem;
    }
