      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--c-glass-strong);
      border: 1px solid var(--c-border-08);
      cursor: pointer;
      color: var(--c-text-50);
      font-size: 1.125rem;
      z-index: 2;
    }
    .configurator-close-picker:hover {
      background: var(--c-green-bg-10);
      color: var(--c-green-text);
    }
    .configurator-total {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      padding: 1rem;
      border-radius: 16px;
      background: var(--c-glass-strong);
      border: 1px solid var(--c-green-border-20);
      margin-top: 1rem;
    }
    .configurator-total .total-item { text-align: center; }
    .configurator-total .total-value {
      font-size: 1.5rem;
      font-weight: 800;
      line-height: 1.2;
    }
    .configurator-total .total-label {
