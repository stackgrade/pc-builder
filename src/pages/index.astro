  <script>
    // Client-side budget switching
    const BUDGET_MAP = {
      7000: 0,
      10000: 1,
      15000: 2,
      20000: 3
    };
    const BUDGETS = [7000, 10000, 15000, 20000];

    function getBudgetFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const budget = parseInt(params.get('budget') || '10000');
      return BUDGETS.includes(budget) ? budget : 10000;
    }

    function switchBuild(index) {
      // Update URL
      const budget = BUDGETS[index];
      const url = new URL(window.location.href);
      url.searchParams.set('budget', budget.toString());
      window.history.pushState({}, '', url);

      // Update build sections
      document.querySelectorAll('.build-section').forEach((el, i) => {
        el.classList.toggle('visible', i === index);
      });

      // Update stats bar
      document.querySelectorAll('.build-stats').forEach((el, i) => {
        el.classList.toggle('visible', i === index);
      });

      // Update tier selector
      document.querySelectorAll('.tier-btn').forEach((el, i) => {
        const isActive = i === index;
        el.classList.toggle('active', isActive);
        el.classList.toggle('glass-strong', isActive);
        el.classList.toggle('glass', !isActive);
      });

      // Update all builds grid
      document.querySelectorAll('.summary-card[data-index]').forEach((el) => {
        const elIndex = parseInt(el.getAttribute('data-index') || '0');
        el.classList.toggle('active', elIndex === index);
      });
    }

    // Init on page load
    document.addEventListener('DOMContentLoaded', () => {
      const budget = getBudgetFromUrl();
      const index = BUDGET_MAP[budget];
      switchBuild(index);

      // Tier selector clicks
      document.querySelectorAll('.tier-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.getAttribute("data-index") || "0");
          switchBuild(idx);
        });
      });

      // All builds grid clicks
      document.querySelectorAll('.summary-card[data-index]').forEach(card => {
        card.addEventListener('click', () => {
          const idx = parseInt(card.getAttribute("data-index") || "0");
          switchBuild(idx);
        });
      });

      // Handle browser back/forward
      window.addEventListener('popstate', () => {
        const budget = getBudgetFromUrl();
        const index = BUDGET_MAP[budget];
        switchBuild(index);
      });

      // AI Build Suggestion — use case chips
      document.querySelectorAll('.use-case-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const budget = parseInt(chip.getAttribute('data-budget') || '10000');
          const index = BUDGET_MAP[budget];
          if (index !== undefined) {
            switchBuild(index);
            // Smooth scroll to budget selector
            const target = document.getElementById('tier-selector');
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Component browser tabs
      const compTabs = document.querySelectorAll('.comp-tab');
      const compGrids = document.querySelectorAll('.comp-grid');

      function switchCompCategory(category) {
        compTabs.forEach(tab => {
          const isActive = tab.getAttribute('data-category') === category;
          tab.classList.toggle('active', isActive);
          tab.className = tab.className
            .replace(/glass-?[^\s]*/g, '')
            .replace(/border-[^\s]*/g, '')
            .replace(/c-[^\s]*/g, '')
            .replace(/hover:[^\s]*/g, '')
            .trim();
          if (isActive) {
            tab.classList.add('glass-strong', 'border', 'border-green-500/30', 'c-green-text', 'px-3', 'py-1.5', 'rounded-lg', 'text-xs', 'font-semibold', 'uppercase', 'tracking-wider');
          } else {
            tab.classList.add('glass', 'border', 'c-border-06', 'c-text-50', 'hover:c-text-80', 'hover:border-c-border-08', 'px-3', 'py-1.5', 'rounded-lg', 'text-xs', 'font-semibold', 'uppercase', 'tracking-wider');
          }
        });
        compGrids.forEach(grid => {
          grid.classList.toggle('visible', grid.getAttribute('data-category') === category);
        });
      }

      compTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const cat = tab.getAttribute('data-category');
          if (cat) switchCompCategory(cat);
        });
      });
    });
  </script>

  <script>
    // Price History SVG Chart
    const chartDataElement = document.getElementById('history-data');
    if (chartDataElement) {
      const componentHistory = JSON.parse(chartDataElement.textContent || '{}');
      const chartSvg = document.getElementById('price-chart');
      const historySelect = document.getElementById('history-select');
      const noData = document.getElementById('chart-no-data');

      function renderChart(componentName) {
        const data = componentHistory[componentName];
        if (!data || data.length < 2) {
          chartSvg.classList.add('hidden');
          if (noData) noData.classList.remove('hidden');
          return;
        }
        chartSvg.classList.remove('hidden');
        if (noData) noData.classList.add('hidden');

        const svg = chartSvg;
        const W = 800, H = 320;
        const pad = { top: 30, right: 30, bottom: 50, left: 60 };
        const plotW = W - pad.left - pad.right;
        const plotH = H - pad.top - pad.bottom;

        // Determine price range
        const prices = data.map(d => d.price);
        const minPrice = Math.min(...prices);
        const maxPrice = Math.max(...prices);
        const priceRange = maxPrice - minPrice || 1;
        const padding = priceRange * 0.1;

        const yMin = Math.max(0, minPrice - padding);
        const yMax = maxPrice + padding;

        const xScale = (i) => pad.left + (i / (data.length - 1)) * plotW;
        const yScale = (p) => pad.top + plotH - ((p - yMin) / (yMax - yMin)) * plotH;

        const trend = prices[prices.length - 1] <= prices[0] ? 'down' : 'up';
        const lineColor = trend === 'down' ? '#22c55e' : '#ef4444';
        const areaGradient = trend === 'down'
          ? 'url(#greenGrad)' : 'url(#redGrad)';

        let svgContent = `<!-- Grid lines -->`;

        // Y-axis grid lines (5 horizontal lines)
        for (let i = 0; i <= 4; i++) {
          const y = pad.top + (plotH / 4) * i;
          const val = yMax - (yMax - yMin) * (i / 4);
          svgContent += `
            <line x1="${pad.left}" y1="${y}" x2="${W - pad.right}" y2="${y}" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <text x="${pad.left - 8}" y="${y + 4}" text-anchor="end" fill="rgba(255,255,255,0.35)" font-size="11">${Math.round(val).toLocaleString('sv-SE')}</text>`;
        }

        // X-axis labels
        const skip = Math.max(1, Math.floor(data.length / 6));
        data.forEach((d, i) => {
          if (i % skip === 0 || i === data.length - 1) {
            const x = xScale(i);
            const parts = d.date.split('-');
            const label = parts[1] + '/' + parts[2];
            svgContent += `
              <text x="${x}" y="${H - pad.bottom + 20}" text-anchor="middle" fill="rgba(255,255,255,0.35)" font-size="10">${label}</text>`;
          }
        });

        // Area fill
        let areaPoints = data.map((d, i) => `${xScale(i)},${yScale(d.price)}`).join(' ');
        svgContent += `
          <polygon fill="${areaGradient}" opacity="0.15" points="${pad.left},${pad.top + plotH} ${areaPoints} ${xScale(data.length - 1)},${pad.top + plotH}"/>`;

        // Line
        let linePoints = data.map((d, i) => `${xScale(i)},${yScale(d.price)}`).join(' ');
        svgContent += `
          <polyline fill="none" stroke="${lineColor}" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" points="${linePoints}"/>`;

        // Dots with tooltips
        data.forEach((d, i) => {
          const x = xScale(i);
          const y = yScale(d.price);
          const isFirst = i === 0;
          const isLast = i === data.length - 1;
          const r = (isFirst || isLast) ? 5 : 3;
          const fill = (isFirst || isLast) ? lineColor : 'rgba(255,255,255,0.3)';
          svgContent += `
            <circle cx="${x}" cy="${y}" r="${r}" fill="${fill}" stroke="${lineColor}" stroke-width="1.5" opacity="0.8">
              <title>${d.date}: ${d.price.toLocaleString('sv-SE')} kr</title>
            </circle>`;

          // First and last price labels
          if (isFirst) {
            svgContent += `
              <text x="${x}" y="${y - 10}" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="10">${d.price.toLocaleString('sv-SE')} kr</text>`;
          }
          if (isLast) {
            svgContent += `
              <text x="${x}" y="${y - 10}" text-anchor="middle" fill="${lineColor}" font-size="11" font-weight="bold">${d.price.toLocaleString('sv-SE')} kr</text>`;
          }
        });

        // Trend label
        const pctChange = ((prices[prices.length - 1] - prices[0]) / prices[0] * 100).toFixed(1);
        const trendSymbol = trend === 'down' ? '↓' : '↑';
        const trendText = `${trendSymbol} ${Math.abs(pctChange)}% på 13 veckor`;
        svgContent += `
          <text x="${W - pad.right}" y="${pad.top + 18}" text-anchor="end" fill="${lineColor}" font-size="12" font-weight="bold">${trendText}</text>`;

        // Defs for gradients
        const defs = `
          <defs>
            <linearGradient id="greenGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#22c55e"/>
              <stop offset="100%" stop-color="#22c55e" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="redGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#ef4444"/>
              <stop offset="100%" stop-color="#ef4444" stop-opacity="0"/>
            </linearGradient>
          </defs>`;

        svg.innerHTML = defs + svgContent;
      }

      // Initialize with first component
      if (historySelect && componentHistory[historySelect.value]) {
        renderChart(historySelect.value);
      }

      // Handle selection change
      if (historySelect) {
        historySelect.addEventListener('change', () => {
          renderChart(historySelect.value);
        });
      }
    }
  </script>

  <script>
    // Build Configurator — interactive component swapping
    (function() {
      'use strict';

      // Parse embedded data
      const catalogEl = document.getElementById('components-catalog');
      const configDataEl = document.getElementById('config-data');
      if (!catalogEl || !configDataEl) return;

      const components = JSON.parse(catalogEl.textContent || '{}');
      const configMeta = JSON.parse(configDataEl.textContent || '{}');
      const { socketToRamType, psuRecommendations, priceClasses } = configMeta;

      // Category -> plural key mapping
      const catKey = { cpu: 'cpus', gpu: 'gpus', ram: 'ram', motherboard: 'motherboards', storage: 'storage', case: 'cases', psu: 'psus' };

      // Component icons inline SVG (matching original design)
      const icons = {
        cpu: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>',
        gpu: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-6.75a2.25 2.25 0 012.25-2.25h18a2.25 2.25 0 012.25 2.25v6.75"/></svg>',
        ram: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 5.25h-16.5m16.5 0v10.5a2.25 2.25 0 01-2.25 2.25h-11.5a2.25 2.25 0 01-2.25-2.25V5.25m16.5 0v10.5a2.25 2.25 0 002.25 2.25h-11.5a2.25 2.25 0 00-2.25 2.25V5.25m16.5 0H3.75"/></svg>',
        storage: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 9a.75.75 0 00-.75.75v9a.75.75 0 00.75.75h19.5a.75.75 0 00.75-.75V9a.75.75 0 00-.75-.75H2.25zM2.25 6a.75.75 0 00-.75.75v6c0 .414.336.75.75.75h19.5a.75.75 0 00.75-.75V6.75A.75.75 0 0021.75 6H2.25z"/></svg>',
        motherboard: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5M4.5 15.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>',
        case: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/></svg>',
        psu: '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>',
      };

      function fmtPrice(p) { return p.toLocaleString('sv-SE') + ' kr'; }

      // Current selections state per build: { index: { cpu: {...}, gpu: {...}, ... } }
      const selections = {};

      // Store originals on init
      function storeOriginals(buildIndex, buildComponents) {
        if (!selections[buildIndex]) selections[buildIndex] = {};
        // Only store if not already set (keep across toggle toggles)
        if (Object.keys(selections[buildIndex]).length === 0) {
          Object.entries(buildComponents).forEach(([slot, comp]) => {
            selections[buildIndex][slot] = { ...comp };
          });
        }
      }

      function getSlotItems(slot) {
        const key = catKey[slot] || slot + 's';
        return components[key] || [];
      }

      // Calculate total performance for a set of components
      function calcPerformance(comps) {
        return Math.round(
          (comps.cpu?.performance || 0) * 0.25 +
          (comps.gpu?.performance || 0) * 0.45 +
          (comps.ram?.performance || 50) * 0.08 +
          (comps.storage?.performance || 50) * 0.07 +
          (comps.motherboard?.performance || 50) * 0.10 +
          (comps.psu?.performance || 50) * 0.05
        );
      }

      function calcTotalPrice(comps) {
        return (comps.cpu?.price || 0) + (comps.gpu?.price || 0) + (comps.ram?.price || 0) +
               (comps.storage?.price || 0) + (comps.motherboard?.price || 0) +
               (comps.case?.price || 0) + (comps.psu?.price || 0);
      }

      function recalcForBuild(buildIndex) {
        const s = selections[buildIndex];
        if (!s) return;
        const totalPrice = calcTotalPrice(s);
        const perf = calcPerformance(s);
        const ppk = totalPrice > 0 ? Math.round((perf / totalPrice) * 1000 * 10) / 10 : 0;

        // Update total display
        const panel = document.querySelector(`.configurator-panel[data-index="${buildIndex}"]`);
        if (!panel) return;
        const priceEl = panel.querySelector('.configurator-total-price');
        const perfEl = panel.querySelector('.configurator-total-perf');
        const ppkEl = panel.querySelector('.configurator-total-ppk');
        if (priceEl) priceEl.textContent = fmtPrice(totalPrice);
        if (perfEl) perfEl.textContent = String(perf);
        if (ppkEl) ppkEl.textContent = String(ppk);

        // Also update the main build card display?
        // Update each slot display
        const slots = panel.querySelectorAll('.configurator-slot');
        slots.forEach(el => {
          const slot = el.getAttribute('data-slot');
          const comp = s[slot];
          if (!comp) return;
          const nameEl = el.querySelector('.configurator-comp-name');
          const priceEl2 = el.querySelector('.configurator-comp-price');
          const ppkEl2 = el.querySelector('.configurator-comp-ppk');
          if (nameEl) nameEl.textContent = comp.name;
          if (priceEl2) priceEl2.textContent = fmtPrice(comp.price);
          if (ppkEl2) ppkEl2.textContent = (comp.performancePerKrona || 0) + '/1000kr';
        });
      }

      function openPicker(buildIndex, slot) {
        const panel = document.querySelector(`.configurator-panel[data-index="${buildIndex}"]`);
        if (!panel) return;
        const s = selections[buildIndex];
        if (!s) return;
        const current = s[slot];
        if (!current) return;

        const budget = priceClasses[buildIndex];
        const items = getSlotItems(slot);

        // Compute "locked" cost of other slots
        let lockedCost = 0;
        Object.entries(s).forEach(([key, comp]) => {
          if (key !== slot) lockedCost += comp.price;
        });
        const remainingBudget = budget - lockedCost;

        // Close any existing picker
        const existing = panel.querySelector('.configurator-picker');
        if (existing) existing.remove();

        const compMeta = {
          cpu: { label: 'CPU', icon: icons.cpu },
          gpu: { label: 'GPU', icon: icons.gpu },
          ram: { label: 'RAM', icon: icons.ram },
          storage: { label: 'SSD', icon: icons.storage },
          motherboard: { label: 'Moderkort', icon: icons.motherboard },
          case: { label: 'Chassi', icon: icons.case },
          psu: { label: 'PSU', icon: icons.psu },
        };
        const meta = compMeta[slot] || { label: slot.toUpperCase(), icon: icons.cpu };

        // Check compatibility hints
        function getCompatWarnings(comp) {
          const warns = [];
          if (slot === 'cpu') {
            if (s.motherboard && comp.socket !== s.motherboard.socket) warns.push('⚡ Socket mismatch');
          }
          if (slot === 'motherboard') {
            if (s.cpu && comp.socket !== s.cpu.socket) warns.push('⚡ Socket mismatch');
          }
          if (slot === 'ram') {
            const cpu = s.cpu;
            const neededType = socketToRamType[cpu?.socket || ''] || 'DDR4';
            if (comp.ramType && comp.ramType !== neededType) warns.push('⚡ RAM type mismatch (' + neededType + ' krävs)');
          }
          if (slot === 'psu') {
            const gpu = s.gpu;
            const minWatt = psuRecommendations[gpu?.name || ''] || 650;
            if ((comp.wattage || 0) < minWatt) warns.push('⚠ Only ' + comp.wattage + 'W (need ≥' + minWatt + 'W)');
          }
          return warns;
        }

        const picker = document.createElement('div');
        picker.className = 'configurator-picker open';
        picker.innerHTML = `
          <div class="flex items-center gap-2 mb-3">
            <div class="icon-container w-8 h-8 flex items-center justify-center c-green-text flex-shrink-0">${meta.icon}</div>
            <span class="font-bold c-text text-sm">Välj ${meta.label}</span>
            <span class="text-xs c-text-30 ml-auto">Budget: ${fmtPrice(budget)}</span>
          </div>
          <button class="configurator-close-picker" type="button" aria-label="Stäng">✕</button>
          <div style="max-height:280px;overflow-y:auto;">
            ${items.map(comp => {
              const isSelected = current.id === comp.id;
              const overBudget = comp.price > remainingBudget && !isSelected;
              const warns = getCompatWarnings(comp);
              return `
                <div class="configurator-picker-item ${isSelected ? 'selected' : ''} ${overBudget ? 'opacity-50' : ''}"
                     data-id="${comp.id}"
                     role="button" tabindex="0">
                  <div class="flex items-center gap-3 flex-1 min-w-0">
                    <span class="pick-check text-sm ${isSelected ? 'c-green-text' : 'c-text-30'}">${isSelected ? '✓' : ''}</span>
                    <span class="comp-name">${comp.name}</span>
                    ${warns.length ? warns.map(w => `<span class="comp-warn">${w}</span>`).join('') : ''}
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    ${overBudget ? '<span class="text-xs text-red-400">+${' + fmtPrice(comp.price - remainingBudget) + '}</span>' : ''}
                    <span class="comp-price">${fmtPrice(comp.price)}</span>
                    <span class="comp-ppk">${comp.performancePerKrona || 0}/1k</span>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        `;

        // Insert picker inside the slot card
        const slotEl = panel.querySelector(`.configurator-slot[data-slot="${slot}"]`);
        if (slotEl) {
          slotEl.style.position = 'relative';
          slotEl.appendChild(picker);
        }

        // Handle selection
        function selectItem(el) {
          const id = el.getAttribute('data-id');
          const compObj = items.find(c => c.id === id);
          if (!compObj) return;
          selections[buildIndex][slot] = { ...compObj };
          recalcForBuild(buildIndex);
          picker.remove();
          // Re-open needed for compatibility check refresh
        }

        picker.querySelectorAll('.configurator-picker-item').forEach(item => {
          item.addEventListener('click', () => selectItem(item));
          item.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectItem(item); }
          });
        });

        // Close button
        picker.querySelector('.configurator-close-picker')?.addEventListener('click', () => picker.remove());

        // Close on backdrop click (click outside picker but inside slot)
        setTimeout(() => {
          const closer = (e) => {
            if (!picker.contains(e.target) || e.target.closest('.configurator-close-picker')) {
              picker.remove();
              document.removeEventListener('click', closer);
            }
          };
          document.addEventListener('click', closer);
        }, 100);
      }

      // Toggle configurator panel
      function toggleConfigurator(buildIndex) {
        const panel = document.querySelector(`.configurator-panel[data-index="${buildIndex}"]`);
        if (!panel) return;
        const btn = document.querySelector(`.configurator-toggle[data-index="${buildIndex}"]`);
        const isOpen = panel.style.display !== 'none';
        panel.style.display = isOpen ? 'none' : 'block';
        if (btn) {
          btn.classList.toggle('bg-green-500/10', !isOpen);
          btn.classList.toggle('border-green-500/50', !isOpen);
          btn.innerHTML = isOpen
            ? '<span class="flex items-center gap-2"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m6.894 5.785l-1.149-.964M6.256 7.178l-1.15-.964m15.352 8.864l-1.41-.513M4.954 9.435l-1.41-.514M12.002 12l-3.75 6.495"/></svg><span>Anpassa komponenter</span></span>'
            : '<span class="flex items-center gap-2"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg><span>Stäng konfigurator</span></span>';
        }
      }

      // Reset build to original components
      function resetBuild(buildIndex) {
        const panel = document.querySelector(`.configurator-panel[data-index="${buildIndex}"]`);
        if (!panel) return;
        // Need original build data — re-read from the main build card components
        const mainSection = document.querySelector(`.build-section[data-index="${buildIndex}"]`);
        if (!mainSection) return;
        const compCards = mainSection.querySelectorAll('.component-card');
        if (!compCards.length) return;

        const s = selections[buildIndex] || {};
        // Reset each slot from the main display
        const mainCompNames = [];
        compCards.forEach(card => {
          const nameEl = card.querySelector('p.font-medium');
          const priceEl = card.querySelector('.text-lg.font-bold.c-text');
          if (nameEl) mainCompNames.push(nameEl.textContent?.trim() || '');
        });

        // Re-read original components from catalog by name
        const slotKeys = Object.keys(catKey);
        compCards.forEach((card, idx) => {
          if (idx >= slotKeys.length) return;
          const slot = slotKeys[idx];
          const name = mainCompNames[idx];
          if (name) {
            const items = getSlotItems(slot);
            const orig = items.find(c => c.name === name);
            if (orig) s[slot] = { ...orig };
          }
        });

        recalcForBuild(buildIndex);
      }

      // Init
      document.addEventListener('DOMContentLoaded', () => {
        // Build sections data for initializing selections
        const buildSections = document.querySelectorAll('.build-section');
        buildSections.forEach((section, idx) => {
          const componentCards = section.querySelectorAll('.component-card');
          const comps = { cpu: null, gpu: null, ram: null, storage: null, motherboard: null, case: null, psu: null };
          const slotKeys = Object.keys(comps);
          componentCards.forEach((card, i) => {
            if (i >= slotKeys.length) return;
            const nameEl = card.querySelector('p.font-medium');
            const priceEl = card.querySelector('.text-lg.font-bold.c-text');
            if (nameEl) {
              const name = nameEl.textContent?.trim() || '';
              const priceText = priceEl?.textContent?.trim() || '';
              const price = parseInt(priceText.replace(/\s/g, '').replace('kr', '')) || 0;
              const slot = slotKeys[i];
              const items = getSlotItems(slot);
              const found = items.find(c => c.name === name) || items.find(c => c.price === price) || null;
              if (found) comps[slot] = { ...found };
            }
          });
          storeOriginals(idx, comps);
        });

        // Toggle buttons
        document.querySelectorAll('.configurator-toggle').forEach(btn => {
          btn.addEventListener('click', () => {
            const idx = parseInt(btn.getAttribute('data-index') || '0');
            toggleConfigurator(idx);
          });
        });

        // Pick buttons
        document.querySelectorAll('.configurator-pick-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(btn.getAttribute('data-index') || '0');
            const slot = btn.getAttribute('data-slot');
            openPicker(idx, slot);
          });
        });

        // Reset buttons
        document.querySelectorAll('.configurator-cancel').forEach(btn => {
          btn.addEventListener('click', () => {
            const idx = parseInt(btn.getAttribute('data-index') || '0');
            resetBuild(idx);
          });
        });
      });
    })();
  </script>
</Layout>