---
import 'uno.css';
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="PC Builder SE - Hitta bästa prestanda per krona för din nästa dator. Jämför priser från svenska återförsäljare." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-dark text-gray-200 min-h-screen">
    <slot />
  </body>
</html>
